# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub

# One Google Sheet ID per commodity — reuse these same sheets every year
# Get from URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
SHEET_ID_WHEAT=paste_wheat_sheet_id_here
SHEET_ID_PEAS=paste_peas_sheet_id_here
SHEET_ID_POTATOES=paste_potatoes_sheet_id_here
SHEET_ID_ONIONS=paste_onions_sheet_id_here

# Google Service Account JSON (minified, on one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Settings screen password (default: 8200)
SETTINGS_PASSWORD=8200

# Default crop year shown when app first starts
# You can override this anytime in the app's Settings screen
DEFAULT_CROP_YEAR=2026

# Port (Render sets this automatically)
PORT=3001
